---
import '../styles/globals.css';
import { ViewTransitions } from 'astro:transitions';
import Sidebar from '~/components/home/Sidebar.astro';
import MobileNav from '~/components/home/MobileNav.astro';

interface BlogPost {
  slug: string;
  title: string;
}

interface Props {
  title: string;
  description: string;
  activePage?: string;
  showSections?: boolean;
  blogPosts?: BlogPost[];
  activePost?: string;
}

const { title, description, activePage = 'home', showSections = false, blogPosts = [], activePost = '' } = Astro.props;
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:image" content={new URL('/og.png', Astro.site)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/og.png', Astro.site)} />
    <title>{title}</title>
    <ViewTransitions />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,400;0,500;0,700;1,400;1,500;1,700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --astro-code-color-text: #e4e4e7;
        --astro-code-color-background: #18181b;
        --astro-code-token-constant: #d4d4d8;
        --astro-code-token-string: #a1a1aa;
        --astro-code-token-comment: #71717a;
        --astro-code-token-keyword: #f4f4f5;
        --astro-code-token-parameter: #d4d4d8;
        --astro-code-token-function: #e4e4e7;
        --astro-code-token-string-expression: #a1a1aa;
        --astro-code-token-punctuation: #71717a;
        --astro-code-token-link: #a1a1aa;
      }

      body {
        font-family: 'IBM Plex Mono', monospace;
      }
    </style>
  </head>
  <body>
    <div class="flex h-dvh overflow-hidden bg-surface" transition:animate="none">
      <Sidebar activePage={activePage} showSections={showSections} blogPosts={blogPosts} activePost={activePost} />
      <div class="flex-1 flex flex-col overflow-hidden" transition:animate="none">
        <div class="md:hidden">
          <MobileNav activePage={activePage} showSections={showSections} blogPosts={blogPosts} activePost={activePost} />
        </div>
        <slot />
      </div>
    </div>
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        sessionStorage.removeItem('v1-scroll-delta');
        sessionStorage.removeItem('v1-scroll-top');
      }, { once: true });

      document.addEventListener('astro:after-swap', () => {
        const el = document.getElementById('v1-scroll');
        if (!el) return;
        const saved = sessionStorage.getItem('v1-scroll-top');
        if (saved) el.scrollTop = parseFloat(saved);
      });
    </script>
  </body>
</html>
