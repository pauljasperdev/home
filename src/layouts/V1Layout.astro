---
import '../styles/globals.css';
import { ViewTransitions } from 'astro:transitions';
import Sidebar from '~/components/home/Sidebar.astro';

interface BlogPost {
  slug: string;
  title: string;
}

interface Props {
  title: string;
  description: string;
  activePage?: string;
  showSections?: boolean;
  blogPosts?: BlogPost[];
  activePost?: string;
}

const { title, description, activePage = 'home', showSections = false, blogPosts = [], activePost = '' } = Astro.props;
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <ViewTransitions />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,400;0,500;0,700;1,400;1,500;1,700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --astro-code-color-text: #e4e4e7;
        --astro-code-color-background: #18181b;
        --astro-code-token-constant: #d4d4d8;
        --astro-code-token-string: #a1a1aa;
        --astro-code-token-comment: #71717a;
        --astro-code-token-keyword: #f4f4f5;
        --astro-code-token-parameter: #d4d4d8;
        --astro-code-token-function: #e4e4e7;
        --astro-code-token-string-expression: #a1a1aa;
        --astro-code-token-punctuation: #71717a;
        --astro-code-token-link: #a1a1aa;
      }

      body {
        font-family: 'IBM Plex Mono', monospace;
      }
    </style>
  </head>
  <body>
    <div style="display:flex;height:100vh;overflow:hidden;background:#09090b;" transition:animate="none">
      <Sidebar activePage={activePage} showSections={showSections} blogPosts={blogPosts} activePost={activePost} />
      <div style="flex:1;display:flex;flex-direction:column;" transition:animate="none">
        <slot />
      </div>
    </div>
  </body>
</html>
