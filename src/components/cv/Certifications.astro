---
import type { CertificateType } from '../../lib/types';

interface Props {
  certifications: CertificateType[];
}
const { certifications } = Astro.props;
---

<section class="avoid-break flex flex-col gap-2 print:gap-2">
  <h2 class="border-b border-black text-lg font-bold uppercase tracking-wider print:text-sm">
    Certifications
  </h2>

  <div class="flex flex-col gap-0.5">
    <div class="grid grid-cols-2 gap-x-4 gap-y-0.5 print:gap-y-0">
      {certifications.map((cert) => (
        <div class="flex justify-between text-sm print:my-0 print:text-[9px] print:leading-none">
          <span>
            {cert.title}
            <span class="italic text-gray-600">
              {" " + cert.description}
            </span>
          </span>
          <span class="self-center text-xs italic text-gray-600 print:text-[8px]">
            {cert.date}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>
