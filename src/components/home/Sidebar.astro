---
interface BlogPost {
  slug: string;
  title: string;
}

interface Props {
  activePage?: string;
  showSections?: boolean;
  blogPosts?: BlogPost[];
  activePost?: string;
}

const { activePage = 'home', showSections = false, blogPosts = [], activePost = '' } = Astro.props;

const sections = [
  { label: 'Welcome', id: 'welcome' },
  { label: 'Experience', id: 'experience' },
  { label: 'Projects', id: 'projects' },
  { label: 'Certifications', id: 'certifications' },
  { label: 'Education', id: 'education' },
];
---

<aside class="hidden md:flex w-[200px] shrink-0 h-dvh overflow-y-auto border-r border-edge px-6 py-8 flex-col gap-8 bg-surface sticky top-0">
  <div class="flex flex-col gap-4 items-start">
    <div class="rounded-md overflow-hidden">
      <img src="/profile.svg" alt="Logo" class="w-full h-auto block" />
    </div>
    <div class="text-base font-medium text-bright tracking-wide">
      Paul Jasper
    </div>

  </div>

  {showSections && (
    <nav class="flex flex-col gap-[0.1rem]">
      <div class="text-[0.7rem] text-subtle tracking-[0.12em] uppercase mb-2">On this page</div>
      {sections.map((s) => (
        <a
          href={`#${s.id}`}
          data-nav-section={s.id}
          class="text-[0.85rem] text-subtle border-l-2 border-transparent no-underline block py-[0.3rem] px-2 pl-[0.6rem]"
        >
          {s.label}
        </a>
      ))}
    </nav>
  )}

  {blogPosts.length > 0 && (
    <nav class="flex flex-col gap-[0.1rem]">
      <div class="text-[0.7rem] text-subtle tracking-[0.12em] uppercase mb-2">Posts</div>
      {blogPosts.map((p) => {
        const isActive = p.slug === activePost;
        return (
          <a
            href={`/blog/${p.slug}`}
            class={`text-[0.8rem] no-underline block py-[0.3rem] px-2 pl-[0.6rem] leading-[1.4] border-l-2 ${isActive ? 'text-heading border-dim' : 'text-subtle border-transparent'}`}
          >
            {p.title}
          </a>
        );
      })}
    </nav>
  )}

  <nav class="mt-auto flex flex-col gap-[0.1rem]">
    <a href="/" class={`text-sm no-underline block py-1 px-2 pl-[0.6rem] border-l-2 ${activePage === 'home' ? 'text-heading border-dim' : 'text-muted border-transparent'}`}>Home</a>
    <a href="/blog" class={`text-sm no-underline block py-1 px-2 pl-[0.6rem] border-l-2 ${activePage === 'blog' ? 'text-heading border-dim' : 'text-muted border-transparent'}`}>Blog</a>
    <button type="button" id="cv-print-btn" class="text-sm text-muted no-underline block py-1 px-2 bg-transparent border-none cursor-pointer font-mono text-left w-full">↘ CV</button>
    <a href="https://github.com/pauljasperdev" target="_blank" rel="noopener noreferrer" class="text-sm text-muted no-underline block py-1 px-2 bg-transparent border-none cursor-pointer font-mono text-left w-full">↗ GitHub</a>
    <a href="https://x.com/pauljasperdev" target="_blank" rel="noopener noreferrer" class="text-sm text-muted no-underline block py-1 px-2 bg-transparent border-none cursor-pointer font-mono text-left w-full">↗ Twitter</a>
    <a href="mailto:mail@pauljasper.dev" class="text-sm text-muted no-underline block py-1 px-2 bg-transparent border-none cursor-pointer font-mono text-left w-full">↗ Email</a>
  </nav>
</aside>

<script>
  function initSidebar() {
    document.getElementById('cv-print-btn')?.addEventListener('click', () => {
      const frame = document.createElement('iframe');
      frame.style.cssText = 'position:fixed;width:0;height:0;opacity:0;pointer-events:none;';
      frame.src = '/cv';
      frame.onload = () => {
        const orig = document.title;
        document.title = 'Paul-Jasper_Sahr_CV';
        frame.contentWindow?.print();
        document.title = orig;
        setTimeout(() => document.body.removeChild(frame), 2000);
      };
      document.body.appendChild(frame);
    });

    const container = document.getElementById('v1-scroll');
    if (!container) return;

    const navLinks = document.querySelectorAll<HTMLAnchorElement>('[data-nav-section]');
    if (navLinks.length === 0) return;

    function update() {
      const sections = container!.querySelectorAll<HTMLElement>('[data-section]');
      if (sections.length === 0) return;

      const scrollTop = container!.scrollTop;
      const viewportHeight = container!.clientHeight;
      const detectionLine = scrollTop + viewportHeight * 0.3;

      let active = sections[0];
      for (const section of sections) {
        if (section.offsetTop <= detectionLine) {
          active = section;
        }
      }

      const activeName = active?.getAttribute('data-section');
      navLinks.forEach((link) => {
        const isActive = link.getAttribute('data-nav-section') === activeName;
        link.style.color = isActive ? '#e4e4e7' : '#52525b';
        link.style.borderLeftColor = isActive ? '#71717a' : 'transparent';
      });
    }

    container.addEventListener('scroll', update, { passive: true });
    setTimeout(update, 300);
  }

  document.addEventListener('astro:page-load', initSidebar);
</script>
