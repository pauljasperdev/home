---
import V1Layout from '~/layouts/V1Layout.astro';
---
<V1Layout title="Blog — Paul Jasper" description="Blog posts" activePage="blog">
  <main id="blog-scroll" class="flex-1 h-dvh overflow-y-auto [scrollbar-width:none] p-12">
    <div class="max-w-[680px]">
      <div class="text-xs text-dim tracking-[0.15em] uppercase mb-6">— Blog</div>
      <p class="text-[0.85rem] text-dim mt-8">Nothing here yet.</p>
    </div>
  </main>
</V1Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    const el = document.getElementById('blog-scroll');
    if (!el) return;
    const saved = sessionStorage.getItem('blog-scroll-top');
    if (saved) el.scrollTop = parseFloat(saved);
    el.addEventListener('scroll', () => {
      sessionStorage.setItem('blog-scroll-top', String(el.scrollTop));
    }, { passive: true });
  });
</script>

<style>
  main::-webkit-scrollbar { display: none; }
  .prose { color: #b4b4be; font-size: 0.85rem; line-height: 1.8; }
  .prose h2 { color: #e4e4e7; font-size: 1.1rem; font-weight: 500; margin-top: 2.5rem; margin-bottom: 1rem; }
  .prose h3 { color: #d4d4d8; font-size: 0.95rem; font-weight: 500; margin-top: 2rem; margin-bottom: 0.75rem; }
  .prose p { margin-bottom: 1.25rem; }
  .prose a { color: #b4b4be; text-decoration: underline; text-underline-offset: 3px; }
  .prose strong { color: #e4e4e7; font-weight: 500; }
  .prose em { color: #b4b4be; font-style: italic; }
  .prose pre { background: #18181b; border: 1px solid #27272a; border-radius: 4px; padding: 1.25rem; margin: 1.5rem 0; overflow-x: auto; }
  .prose code { font-family: 'IBM Plex Mono', monospace; font-size: 0.78rem; }
  .prose :not(pre) > code { background: #18181b; border: 1px solid #27272a; padding: 0.15rem 0.4rem; border-radius: 3px; font-size: 0.78rem; color: #d4d4d8; }
  .prose ul { padding-left: 1.25rem; margin-bottom: 1.25rem; }
  .prose li { margin-bottom: 0.4rem; }
</style>
